rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ECHOS AT DUSK SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset implements a proximity-based social discovery model centered around a physical venue.
     * Security is built on "Authorization Independence," where documents carry the necessary metadata 
     * (UIDs and Venue IDs) to authorize requests without performing expensive cross-document lookups.
     *
     * Data Structure:
     * - /venues: Publicly viewable metadata about the physical location.
     * - /vibeTags: Publicly viewable global tags for user expression.
     * - /userSessions: Active, temporary user profiles. Authenticated users own their session.
     * - /reactions: Private interactions between two users.
     * - /chatRooms & /messages: Private communication channels for matched users.
     *
     * Key Security Decisions:
     * 1. Ownership Model: User sessions are keyed by the Firebase Auth UID for direct mapping.
     * 2. Shared Access: Reactions and ChatRooms use denormalized UID arrays/fields to grant 
     *    access to both participants simultaneously.
     * 3. Prototyping Flexibility: Rules enforce relational integrity (e.g., UIDs matching auth state) 
     *    but allow for flexible data schemas for rapid iteration.
     * 4. Administrative Control: A dedicated /admin_roles collection manages elevated privileges.
     *
     * Denormalization for Authorization:
     * To ensure high performance and rule simplicity, documents include fields like `participantFirebaseAuthUids` 
     * or `reactorFirebaseAuthUid`. This allows rules to check `request.auth.uid` against document data 
     * without calling `get()`.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user owns the existing document and it exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the user is an administrator based on the admin_roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Publicly readable venue information. Administrative write access only.
     * @path /venues/{venueId}
     * @allow get, list (public)
     * @deny create, update, delete (non-admins)
     * @principle Public lookup data with restricted modification.
     */
    match /venues/{venueId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Publicly readable vibe tags for selection. Administrative write access only.
     * @path /vibeTags/{vibeTagId}
     * @allow get, list (public)
     * @deny create, update, delete (non-admins)
     * @principle Global configuration data restricted to admins.
     */
    match /vibeTags/{vibeTagId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description User sessions are publicly readable for discovery but writable only by the owner.
     * @path /userSessions/{userId}
     * @allow create (owner matching UID), update (owner), list (public discovery)
     * @deny create (mismatched UID), update (changing UID)
     * @principle User ownership and path-to-data consistency.
     */
    match /userSessions/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && request.resource.data.firebaseAuthUserId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.firebaseAuthUserId == resource.data.firebaseAuthUserId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Reactions are private interactions visible only to the two users involved.
     * @path /reactions/{reactionId}
     * @allow get, list (if requester is reactor or target), create (if requester is reactor)
     * @deny create (spoofing reactor UID), update/delete (immutable interactions)
     * @principle Shared access based on denormalized actor UIDs.
     */
    match /reactions/{reactionId} {
      allow get, list: if isSignedIn() && (request.auth.uid == resource.data.reactorFirebaseAuthUid || request.auth.uid == resource.data.targetFirebaseAuthUid);
      allow create: if isSignedIn() && request.resource.data.reactorFirebaseAuthUid == request.auth.uid;
      allow update, delete: if false; // Reactions are typically immutable logs
    }

    /**
     * @description Private chat rooms shared between two specific users.
     * @path /chatRooms/{chatRoomId}
     * @allow get, list (if requester is in participant list)
     * @deny create (client-side creation forbidden), write (managed by backend)
     * @principle Closed collaborator pattern using UID arrays.
     */
    match /chatRooms/{chatRoomId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.userSessionIds;
      allow create, update, delete: if false; // Recommended creation via Cloud Functions for mutual reaction check

      /**
       * @description Messages within a chat room.
       * @path /chatRooms/{chatRoomId}/messages/{messageId}
       * @allow create (if sender is a participant), get/list (if user is a participant)
       * @deny create (if user is not a participant)
       * @principle Relational integrity and shared subcollection access.
       */
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && request.auth.uid in resource.data.participantFirebaseAuthUids;
        allow create: if isSignedIn() && request.resource.data.senderUserSessionId == request.auth.uid && request.auth.uid in request.resource.data.participantFirebaseAuthUids;
        allow update: if isSignedIn() && request.auth.uid in resource.data.participantFirebaseAuthUids; // Allow marking as read
        allow delete: if false;
      }
    }

    /**
     * @description Administrative roles defining DBAC permissions.
     * @path /admin_roles/{userId}
     * @allow get (authenticated users)
     * @deny write (system managed)
     * @principle Database-backed access control for role-based permissions.
     */
    match /admin_roles/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}